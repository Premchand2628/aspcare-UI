# API upstreams
VITE_API_GATEWAY_URL=http://localhost:8080
VITE_AUTH_API_URL=http://localhost:8081
VITE_DEALS_API_URL=http://localhost:8086

# Dev server
VITE_DEV_PORT=3000

# Optional comma-separated host allowlist for Vite dev server
# Example: my-tunnel.ngrok-free.dev,localhost
VITE_ALLOWED_HOSTS=

# QA-only emergency flag (keep false outside controlled QA)
VITE_QA_SKIP_OTP_RATE_LIMIT=false

# Request logging for transaction tracing in browser console
VITE_ENABLE_REQUEST_LOGGING=true
