{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource for log queries",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["carwash", "api", "flow", "prod"],
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "prod,qa,stg",
        "current": { "selected": true, "text": "prod", "value": "prod" },
        "options": [
          { "selected": true, "text": "prod", "value": "prod" },
          { "selected": false, "text": "qa", "value": "qa" },
          { "selected": false, "text": "stg", "value": "stg" }
        ]
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Car Wash — API Flow & Health",
  "uid": "carwash-api-flow",
  "version": 1,
  "weekStart": "",
  "refresh": "30s",

  "panels": [

    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "# API Flow — $env\nLive view of HTTP request/response traffic through the stack.  \n**Client → Nginx → Spring Cloud Gateway (uigateway) → Microservices**  \nNumbers reflect the selected time range."
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "🌐 Nginx · Requests In",
      "description": "All HTTP requests reaching nginx (excluding blocked scanners / static assets — those are dropped before logging).",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\", service=\"nginx\"} |~ \"HTTP/\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "➡️ Gateway · Requests",
      "description": "HTTP_REQUEST count recorded by Spring Cloud Gateway (uigatewayservice).",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"[uigatewayservice]\" |= \"HTTP_REQUEST\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "short", "decimals": 0 },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "📥 Services · Requests",
      "description": "HTTP_REQUEST count across all backend microservices (auth, booking, membership, rates).",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |~ \"\\\\[(?:auth-user-service|bookingservice|membership-service|rates-service|carwashrates|carwash-rates|otploginauth)\\\\]\" |= \"HTTP_REQUEST\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "short", "decimals": 0 },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "✅ 2xx Success",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=2\\\\d\\\\d\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short", "decimals": 0 },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "⚠️ 4xx Client Err",
      "gridPos": { "h": 6, "w": 2, "x": 16, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=4\\\\d\\\\d\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "yellow" }, "unit": "short", "decimals": 0 },
        "overrides": []
      }
    },

    {
      "id": 7,
      "type": "stat",
      "title": "❌ 5xx Server Err",
      "gridPos": { "h": 6, "w": 2, "x": 18, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=5\\\\d\\\\d\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },

    {
      "id": 8,
      "type": "stat",
      "title": "📊 Error Rate",
      "description": "(4xx + 5xx) / total responses",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 3 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "100 * sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=[45]\\\\d\\\\d\" [$__range])) / sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" [$__range]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Request rate per service (req/min)",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 9 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "auth",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({env=\"$env\"} |~ \"\\\\[(?:auth-user-service|otploginauth)\\\\]\" |= \"HTTP_REQUEST\" [1m])) * 60",
          "legendFormat": "auth"
        },
        {
          "refId": "booking",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({env=\"$env\"} |= \"[bookingservice]\" |= \"HTTP_REQUEST\" [1m])) * 60",
          "legendFormat": "booking"
        },
        {
          "refId": "membership",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({env=\"$env\"} |~ \"\\\\[membership(?:-service)?\\\\]\" |= \"HTTP_REQUEST\" [1m])) * 60",
          "legendFormat": "membership"
        },
        {
          "refId": "rates",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({env=\"$env\"} |~ \"\\\\[(?:rates-service|carwashrates|carwash-rates)\\\\]\" |= \"HTTP_REQUEST\" [1m])) * 60",
          "legendFormat": "rates"
        },
        {
          "refId": "gateway",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({env=\"$env\"} |= \"[uigatewayservice]\" |= \"HTTP_REQUEST\" [1m])) * 60",
          "legendFormat": "gateway"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none" }
          },
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 10,
      "type": "piechart",
      "title": "Response status mix",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "2xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=2\\\\d\\\\d\" [$__range]))",
          "legendFormat": "2xx success",
          "queryType": "instant"
        },
        {
          "refId": "3xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=3\\\\d\\\\d\" [$__range]))",
          "legendFormat": "3xx redirect",
          "queryType": "instant"
        },
        {
          "refId": "4xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=4\\\\d\\\\d\" [$__range]))",
          "legendFormat": "4xx client error",
          "queryType": "instant"
        },
        {
          "refId": "5xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=5\\\\d\\\\d\" [$__range]))",
          "legendFormat": "5xx server error",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "pieType": "donut",
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx success" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "3xx redirect" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "4xx client error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "5xx server error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Success vs Error (stacked, per minute)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "2xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=2\\\\d\\\\d\" [1m]))",
          "legendFormat": "2xx"
        },
        {
          "refId": "4xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=4\\\\d\\\\d\" [1m]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "5xx",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"HTTP_RESPONSE\" |~ \"status=5\\\\d\\\\d\" [1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 12,
      "type": "bargauge",
      "title": "Requests by service (time range)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "gateway",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"[uigatewayservice]\" |= \"HTTP_REQUEST\" [$__range]))",
          "legendFormat": "gateway",
          "queryType": "instant"
        },
        {
          "refId": "auth",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |~ \"\\\\[(?:auth-user-service|otploginauth)\\\\]\" |= \"HTTP_REQUEST\" [$__range]))",
          "legendFormat": "auth",
          "queryType": "instant"
        },
        {
          "refId": "booking",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |= \"[bookingservice]\" |= \"HTTP_REQUEST\" [$__range]))",
          "legendFormat": "booking",
          "queryType": "instant"
        },
        {
          "refId": "membership",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |~ \"\\\\[membership(?:-service)?\\\\]\" |= \"HTTP_REQUEST\" [$__range]))",
          "legendFormat": "membership",
          "queryType": "instant"
        },
        {
          "refId": "rates",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({env=\"$env\"} |~ \"\\\\[(?:rates-service|carwashrates|carwash-rates)\\\\]\" |= \"HTTP_REQUEST\" [$__range]))",
          "legendFormat": "rates",
          "queryType": "instant"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },

    {
      "id": 13,
      "type": "table",
      "title": "Top endpoints (by request count)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "topk(20, sum by (method, path) (count_over_time({env=\"$env\"} |= \"HttpRequestResponseLoggingFilter\" |= \"HTTP_REQUEST\" | pattern `<_>HTTP_REQUEST transactionId=<_> method=<method> path=<path> <_>` [$__range])))",
          "queryType": "instant",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "method": "Method",
              "path": "Path",
              "Value": "Requests"
            },
            "indexByName": { "method": 0, "path": 1, "Value": 2 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-BlPu" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Method" },
            "properties": [{ "id": "custom.width", "value": 90 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Requests", "desc": true }]
      }
    },

    {
      "id": 14,
      "type": "table",
      "title": "Errors breakdown — paths returning 4xx / 5xx",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "topk(20, sum by (service, path, status) (count_over_time({env=\"$env\"} |= \"HttpRequestResponseLoggingFilter\" |= \"HTTP_RESPONSE\" |~ \"status=[45]\\\\d\\\\d\" | pattern `<_>HTTP_RESPONSE transactionId=<_> method=<_> path=<path> status=<status> <_>` [$__range])))",
          "queryType": "instant"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "service": "Service",
              "path": "Path",
              "status": "Status",
              "Value": "Count"
            },
            "indexByName": { "service": 0, "path": 1, "status": 2, "Value": 3 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "mappings",
                "value": [
                  { "type": "range", "options": { "from": 400, "to": 499, "result": { "color": "yellow" } } },
                  { "type": "range", "options": { "from": 500, "to": 599, "result": { "color": "red" } } }
                ]
              },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Count" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-YlRd" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Count", "desc": true }]
      }
    }
  ]
}
